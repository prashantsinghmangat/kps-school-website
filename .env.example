# Copy this file to `.env.local` and fill in real values.
# Do NOT commit `.env.local`.

# -- Public (exposed to the browser; keep non-sensitive) -----------------------
NEXT_PUBLIC_SITE_URL=https://www.krishnapublicschoolmeerut.in
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# -- Server-only --------------------------------------------------------------
# Resend: when set, form submissions are emailed. When unset, submissions fall
# back to console log + a JSON file written under os.tmpdir()/kps-submissions/.
RESEND_API_KEY=
FORM_RECIPIENT_EMAIL=krishna.pub.sch@gmail.com
FORM_SENDER_EMAIL=no-reply@krishnapublicschoolmeerut.in

# On-demand revalidation (used by webhook routes later).
REVALIDATE_SECRET=

# Turnstile secret key for server-side CAPTCHA verification.
TURNSTILE_SECRET_KEY=
